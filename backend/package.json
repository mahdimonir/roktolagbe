{
  "name": "roktolagbe-backend",
  "version": "1.0.0",
  "description": "RoktoLagbe - Blood Donation Network API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "test": "jest --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node-dev prisma/seed.ts",
    "prisma:seed:donors": "ts-node-dev prisma/seed-donors.ts",
    "prisma:seed:donors2": "ts-node-dev prisma/seed-donors-2.ts",
    "prisma:seed:all": "npm run prisma:seed && npm run prisma:seed:donors && npm run prisma:seed:donors2",
    "prisma:migrate:reset": "prisma migrate reset --force",
    "prisma:studio": "prisma studio"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ]
  },
  "dependencies": {
    "@prisma/adapter-pg": "^5.12.0",
    "@prisma/client": "^5.12.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.0",
    "pg": "^8.20.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.9",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.12.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}